# Required on Netlify/Vercel for login, wallet, claims — NOT optional if you use accounts/points.
# Production: your deployed Cloudflare Worker URL (no trailing slash), e.g.
# VITE_API_BASE=https://buzzin-api.your-subdomain.workers.dev

# Recycling-Net-11 — POST multipart field `image` → JSON { "label", "confidence" }
# Local:
# VITE_DETECT_API_URL=http://127.0.0.1:8788/detect
# Production (example — your Render/Fly/Railway detect service):
# VITE_DETECT_API_URL=https://buzzin-detect.onrender.com/detect
#
# On the detect host, set BUZZ_DETECT_CORS_ORIGINS=https://your-frontend.vercel.app (comma-separated if multiple)
